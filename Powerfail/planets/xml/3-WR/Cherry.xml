<DialogueTree xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/xen-42/outer-wilds-new-horizons/main/NewHorizons/Schemas/dialogue_schema.xsd">
	<NameField>Elm</NameField>

	<DialogueNode>
		<Name>1</Name>
		<EntryCondition>DEFAULT</EntryCondition>
		<Dialogue>
			<Page>Hello there! I'd be happy to answer any questions you may want.</Page>
		</Dialogue>
		<DialogueOptionsList>
			<DialogueOption>
				<Text>Why is Elm so afraid of Cedar?</Text>
				<DialogueTarget>2</DialogueTarget>
			</DialogueOption>
			<DialogueOption>
				<Text>Why are all of your wrists broken?</Text>
				<DialogueTarget>3</DialogueTarget>
			</DialogueOption>
			<DialogueOption>
				<Text>Have you seen any...strange...blue...glowing..Nomai-y things around anywhere?</Text>
				<DialogueTarget>4</DialogueTarget>
			</DialogueOption>
			<DialogueOption>
				<Text>Bye bye.</Text>
			</DialogueOption>
		</DialogueOptionsList>
	</DialogueNode>

	<DialogueNode>
		<Name>2</Name>
		<EntryCondition>DEFAULT</EntryCondition>
		<Dialogue>
			<Page>He...uh...killed Elm's parents out of pure spite that Elm didn't believe in the prophecy.</Page>
		</Dialogue>
		<DialogueOptionsList>
			<DialogueOption>
				<Text>Oh, I'm so sorry for his loss.</Text>
				<DialogueTarget>1</DialogueTarget>
			</DialogueOption>
		</DialogueOptionsList>
	</DialogueNode>
	<DialogueNode>
		<Name>2</Name>
		<EntryCondition>DEFAULT</EntryCondition>
		<Dialogue>
			<Page>What do you mean? Our wrists are perfectly fine. We were like this since we were born!</Page>
		</Dialogue>
		<DialogueOptionsList>
			<DialogueOption>
				<Text>I doubt that, but okay.</Text>
				<DialogueTarget>1</DialogueTarget>
			</DialogueOption>
		</DialogueOptionsList>
	</DialogueNode>
	<DialogueNode>
		<Name>2</Name>
		<EntryCondition>DEFAULT</EntryCondition>
		<Dialogue>
			<Page>Hm, that sparked a memory. I think Cedar mentioned something like that, but he didn't tell me exactly what it was.</Page>
		</Dialogue>
		<DialogueOptionsList>
			<DialogueOption>
				<Text>Hm. Okay.</Text>
				<DialogueTarget>1</DialogueTarget>
			</DialogueOption>
		</DialogueOptionsList>
	</DialogueNode>
</DialogueTree>